# --- Firebase web SDK config (safe to expose; security lives in Rules + App Check) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- App Check (recaptcha v3 site key) ---
VITE_APP_CHECK_SITE_KEY=

# --- Local development ---
VITE_USE_EMULATORS=false
VITE_USE_FUNCTIONS_EMULATOR=false

# --- Force a fully local "demo mode" (no Firebase writes, mock AI) ---
# Useful for previewing the UI without setting up Firebase.
VITE_DEMO_MODE=false
