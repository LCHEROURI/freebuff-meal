{
  "name": "weeknight-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "sync-schemas": "node scripts/sync-schemas.mjs",
    "check-schemas": "node scripts/check-schemas.mjs",
    "prebuild": "npm run check-schemas",
    "build": "tsc -p tsconfig.json",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@genkit-ai/firebase": "^1.3.0",
    "@genkit-ai/google-cloud": "^1.3.0",
    "@genkit-ai/vertexai": "^1.40.0",
    "@google-cloud/functions-framework": "^3.4.5",
    "@google-cloud/logging": "^11.2.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.2.0",
    "genkit": "^1.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
